# Parameter sweep configuration.
# Space-separated SWEEP_* values generate the Cartesian product.
CASE_START=1000
CASE_END=1003
SWEEP_We="1.0 2.0"
SWEEP_Ohd="0.05 0.1"
SWEEP_Ohs="1e-5"
SWEEP_Bo="0.1"
SWEEP_Ldomain="4.0"
SWEEP_MAXlevel="10"
SWEEP_tmax="25"
SWEEP_tsnap="0.01"
OMP_NUM_THREADS=1
QCC=qcc
QCCFLAGS=-Wall -O2
